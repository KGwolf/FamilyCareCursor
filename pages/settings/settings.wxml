<navigation-bar title="设置" back="{{true}}" custom-back="{{true}}" bindback="onBack" background="#f8f8f6"></navigation-bar>

<scroll-view class="settings-page" scroll-y show-scrollbar="{{false}}">
  <view class="content-wrapper">
    <view class="section-group">
      <view class="section-header">
        <text class="section-title">家人管理</text>
        <view class="add-btn" bindtap="onAddFamily">
          <text class="material-icons add-icon">add</text>
          <text>添加</text>
        </view>
      </view>
      <view class="list-container">
        <view wx:for="{{familyList}}" wx:key="id" class="list-item" hover-class="item-active" bindtap="onEditFamily" data-id="{{item.id}}">
          <view class="item-avatar"></view>
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-relation" style="color: {{item.relationColor}}; background: {{item.relationColor}}10;">{{item.relation}}</text>
          </view>
          <text class="material-icons arrow-icon">chevron_right</text>
        </view>
      </view>
    </view>

    <view class="section-group">
      <view class="section-header">
        <text class="section-title">通知与云端提醒</text>
      </view>
      <view class="list-container">
        <view class="list-item no-arrow">
          <view class="item-left">
            <text class="material-icons icon-blue">notifications_active</text>
            <view class="item-copy">
              <text class="item-text">接收提醒通知</text>
              <text class="item-desc">状态：{{pushStatusText}}</text>
            </view>
          </view>
          <switch checked="{{remindEnabled}}" bindchange="onRemindChange" color="#2F80ED" />
        </view>

        <view class="list-item no-arrow">
          <view class="item-left">
            <text class="material-icons icon-orange">nightlight</text>
            <view class="item-copy">
              <text class="item-text">免打扰时段</text>
              <text class="item-desc">{{quietHoursStart}} - {{quietHoursEnd}}</text>
            </view>
          </view>
          <switch checked="{{quietHoursEnabled}}" bindchange="onQuietHoursChange" color="#2F80ED" />
        </view>

        <view class="list-item compact-row">
          <text class="item-text">开始时间</text>
          <picker mode="time" value="{{quietHoursStart}}" bindchange="onQuietStartChange">
            <view class="picker-value">{{quietHoursStart}}</view>
          </picker>
        </view>

        <view class="list-item compact-row">
          <text class="item-text">结束时间</text>
          <picker mode="time" value="{{quietHoursEnd}}" bindchange="onQuietEndChange">
            <view class="picker-value">{{quietHoursEnd}}</view>
          </picker>
        </view>

        <view class="list-item compact-row">
          <view class="item-copy">
            <text class="item-text">每日推送上限</text>
            <text class="item-desc">超过后当天不再推送</text>
          </view>
          <input class="limit-input" type="number" value="{{dailyPushLimit}}" bindblur="onDailyLimitChange" />
        </view>

        <view class="list-item compact-row">
          <view class="item-copy">
            <text class="item-text">续授权提示次数</text>
            <text class="item-desc">今日已提示 {{subscriptionRenewalPromptCount}} 次，0 表示不自动提示</text>
          </view>
          <input class="limit-input" type="number" value="{{subscriptionRenewalPromptLimit}}" bindblur="onRenewalPromptLimitChange" />
        </view>

        <view class="list-item compact-row">
          <view class="item-copy">
            <text class="item-text">提醒通道</text>
            <text class="item-desc">{{bindingStatusText}}</text>
          </view>
          <picker range="{{channelOptions}}" range-key="label" value="{{channelIndex}}" bindchange="onChannelChange">
            <view class="picker-value">{{channelOptions[channelIndex].label}}</view>
          </picker>
        </view>

        <view wx:if="{{notificationChannel === 'wecom_external'}}" class="list-item" bindtap="onBindWecom" hover-class="item-active">
          <view class="item-copy">
            <text class="item-text">绑定企业微信</text>
            <text class="item-desc">用于长期提醒，可随时在下方关闭云端提醒</text>
          </view>
          <text class="material-icons arrow-icon">chevron_right</text>
        </view>
      </view>

      <view class="privacy-note">
        我们只同步提醒时间和推送状态，不上传家人姓名、健康记录和备注内容。
      </view>

      <view class="list-container danger-container">
        <view class="list-item" bindtap="onRevokeCloudNotifications" hover-class="item-active">
          <view class="item-copy">
            <text class="item-text text-red">关闭云端提醒</text>
            <text class="item-desc">解除通知授权记录，本地数据不会删除</text>
          </view>
          <text class="material-icons arrow-icon">chevron_right</text>
        </view>
      </view>
    </view>

    <view class="section-group">
      <view class="section-header">
        <text class="section-title">提醒管理</text>
      </view>
      <view class="list-container">
        <view class="list-item" hover-class="item-active" bindtap="onManageReminderTypes">
          <view class="item-left-simple">
            <text class="material-icons item-icon-blue">category</text>
            <text class="item-text">维护提醒类型</text>
          </view>
          <text class="material-icons arrow-icon">chevron_right</text>
        </view>
      </view>
    </view>

    <view class="list-container margin-top-lg">
      <view class="list-item" bindtap="onAboutUs" hover-class="item-active">
        <text class="item-text">关于我们</text>
        <text class="material-icons arrow-icon">chevron_right</text>
      </view>
    </view>

    <view class="footer">
      <text class="material-icons footer-icon filled">favorite</text>
      <text class="footer-motto">“记住每一件照护小事”</text>
      <text class="footer-version">Version {{version}}</text>
    </view>

    <tabbar activeTab="settings" />
  </view>
</scroll-view>
