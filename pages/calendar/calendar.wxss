/* pages/calendar/calendar.wxss */

/* 基础配色 */
.calendar-page {
  --primary: #2b8cee;
  --bg-l: #f6f7f8;
  --text-main: #0d141b;
  --text-sec: #64748b;
  --border: #e2e8f0;
  
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--bg-l);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  overflow: hidden;
}

/* 顶部导航内容 */
.nav-left, .nav-right {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  height: 100%;
}

/* 家人选择器 */
.family-header {
  background-color: var(--bg-l);
  padding: 20rpx 30rpx 10rpx 30rpx;
  overflow-x: auto;
}

.family-list {
  display: flex;
  gap: 40rpx;
}

.family-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  opacity: 0.4;
  transition: opacity 0.3s;
}

.family-item.active {
  opacity: 1;
}

.avatar-ring {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: transparent;
}

.active .avatar-ring {
  box-shadow: 0 0 0 4rpx var(--primary);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #e2e8f0;
}

.add-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-sec);
}

.family-name {
  font-size: 22rpx;
  font-weight: 500;
}

.active .family-name {
  color: var(--primary);
  font-weight: bold;
}

/* 主滚动区域 */
.main-scroll {
  flex: 1;
  box-sizing: border-box;
  height: 0;
}

/* 日历卡片 */
.calendar-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 30rpx;
  margin: 10rpx 30rpx 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1rpx solid var(--border);
}

.calendar-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.current-month {
  font-size: 28rpx;
  font-weight: bold;
}

.nav-btn {
  padding: 10rpx;
  color: var(--text-sec);
}

.weekday-header {
  display: flex;
  text-align: center;
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.weekday-header text {
  flex: 1;
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: 14.28%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  position: relative;
}

.day-cell.other-month {
  color: #cbd5e1;
  opacity: 0.5;
}

.day-content {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  position: relative;
}

.day-content.today {
  background-color: var(--primary);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 8rpx 16rpx rgba(43, 140, 238, 0.2);
}

.day-content.selected:not(.today) {
  background-color: rgba(43, 140, 238, 0.1);
  color: var(--primary);
}

.event-dot {
  position: absolute;
  bottom: 6rpx;
  width: 8rpx;
  height: 8rpx;
  background-color: var(--primary);
  border-radius: 50%;
}

.today .event-dot {
  background-color: #fff;
}

/* 任务列表 */
.tasks-section {
  margin-bottom: 40rpx;
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
}

.section-date {
  font-size: 20rpx;
  color: #94a3b8;
  text-transform: uppercase;
}

.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.task-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 32rpx;
  background-color: #fff;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
  border: 1rpx solid var(--border);
}

.task-completed {
  background-color: rgba(37, 99, 235, 0.05);
  border: 1rpx solid rgba(37, 99, 235, 0.1);
}

.task-important {
  border: 4rpx solid rgba(37, 99, 235, 0.2);
}

.task-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.icon-completed {
  background-color: #fff !important;
}

.icon-bg-white {
  background-color: #fff;
}

.icon-bg-sky {
  background-color: #e0f2fe;
}

.icon-bg-amber {
  background-color: #fef3c7;
}

.icon-bg-purple {
  background-color: #f3e8ff;
}

.task-icon {
  font-size: 40rpx;
}

.task-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.task-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.important-tag {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #eaf2ff;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 700;
}

.task-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.title-completed {
  font-weight: 500;
  color: #9ca3af;
  text-decoration: line-through;
}

.task-subtitle {
  font-size: 24rpx;
  color: #6b7280;
  display: flex;
  align-items: center;
}

.subtitle-success {
  color: #2563eb;
  font-weight: 700;
}

.subtitle-note {
  color: #9ca3af;
  font-weight: 400;
}

.task-status {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-completed {
  background-color: #2563eb;
}

.status-pending {
  border: 4rpx solid #d1d5db;
  background-color: transparent;
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.delete-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.delete-btn:active {
  color: #ef4444;
}

.delete-btn .material-icons {
  font-size: 36rpx;
}

/* 温馨提醒卡片 */
.remind-card {
  background: rgba(43, 140, 238, 0.05);
  border: 1rpx solid rgba(43, 140, 238, 0.1);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.remind-info {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}

.remind-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.remind-text {
  font-size: 22rpx;
  color: var(--text-sec);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.remind-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: var(--primary);
  white-space: nowrap;
  flex-shrink: 0;
}

/* 底部导航 */
.tab-bar {
  height: 120rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  border-top: 1rpx solid var(--border);
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  color: #94a3b8;
}

.tab-item.active {
  color: var(--primary);
}

.tab-text {
  font-size: 20rpx;
}

.tab-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -40rpx;
}

.add-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 140, 238, 0.3);
  margin-bottom: 8rpx;
}

.fill {
  font-variation-settings: 'FILL' 1;
}

.safe-bottom-placeholder {
  height: calc(160rpx + env(safe-area-inset-bottom) + 40rpx);
}
