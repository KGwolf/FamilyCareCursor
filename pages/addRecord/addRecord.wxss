/* pages/addRecord/addRecord.wxss */
page {
  background-color: #f8faff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Ensure modal covers entire screen */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10rpx);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  animation: fadeIn 0.3s ease;
}

.add-record-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Nav Styles */
.nav {
  padding: 0 32rpx;
  background-color: #ffffff;
}

.tab-list {
  display: flex;
  border-bottom: 1rpx solid #f1f5f9;
}

.tab-item {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
}

.tab-text.inactive {
  color: #64748b;
  opacity: 0.6;
}

.active-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background-color: #2F80ED;
}

/* Main Content */
.main-content {
  flex: 1;
  padding: 48rpx 32rpx 200rpx;
}

/* Record Time Styling */
.time-picker-card {
  margin-bottom: 48rpx;
  background: #f8fafc;
  padding: 32rpx 40rpx;
  border-radius: 24rpx;
  border: 1rpx solid #f1f5f9;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: transform 0.1s;
}

.time-picker-card:active {
  transform: scale(0.98);
}

.time-label-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-calendar-icon {
  font-size: 36rpx;
  color: #2F80ED;
}

.time-label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #64748b;
}

.time-value-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-value-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #2F80ED;
}

.time-dropdown-icon {
  font-size: 20rpx;
  color: #2F80ED;
  opacity: 0.5;
}

/* Weight Section */
.weight-section {
  margin-bottom: 64rpx;
}

.weight-card {
  background: rgba(47, 128, 237, 0.05);
  border-radius: 32rpx;
  padding: 64rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(47, 128, 237, 0.1);
}

.weight-subtitle {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 400;
  margin-bottom: 24rpx;
}

.weight-display-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.weight-value-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  position: relative;
  width: 100%;
}

.weight-input {
  font-size: 96rpx;
  font-weight: 700;
  color: #0f172a;
  text-align: center;
  width: 300rpx;
  height: 120rpx;
  line-height: 120rpx;
  margin-bottom: 10rpx;
}

.weight-input::placeholder {
  color: #cbd5e1;
}

.weight-unit {
  font-size: 32rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 10rpx;
}

.weight-input-tip {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 10rpx;
}

.diff-tag {
  margin-top: 32rpx;
  background: #ffffff;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(47, 128, 237, 0.05);
}

.diff-text {
  font-size: 26rpx;
  color: #2F80ED;
  font-weight: 500;
}

.diff-highlight {
  font-weight: 700;
}

/* Symptoms Section */
.symptoms-section {
  margin-bottom: 64rpx;
}

.section-header-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
}

.section-subtitle {
  font-size: 22rpx;
  font-weight: 500;
  color: #94a3b8;
}

.symptom-grid {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  box-sizing: border-box;
}

.symptom-col {
  width: 33.33%;
  padding: 0 10rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.symptom-item {
  width: 100%;
  background: #ffffff;
  border: 4rpx solid transparent;
  border-radius: 40rpx;
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  box-sizing: border-box;
}

.symptom-item.selected {
  background: #ffffff;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

.symptom-item.selected.border-primary { border-color: #2F80ED; }
.symptom-item.selected.border-orange { border-color: #fb923c; }
.symptom-item.selected.border-blue { border-color: #60a5fa; }
.symptom-item.selected.border-red { border-color: #f87171; }
.symptom-item.selected.border-purple { border-color: #c084fc; }
.symptom-item.selected.border-slate { border-color: #94a3b8; }

.symptom-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.bg-primary { background-color: rgba(47, 128, 237, 0.05); }
.bg-orange { background-color: rgba(251, 146, 60, 0.08); }
.bg-blue { background-color: rgba(96, 165, 250, 0.08); }
.bg-red { background-color: rgba(248, 113, 113, 0.08); }
.bg-purple { background-color: rgba(192, 132, 252, 0.08); }
.bg-slate { background-color: rgba(148, 163, 184, 0.08); }

.symptom-icon-wrapper.selected {
  transform: scale(1.1);
}

.symptom-icon {
  font-size: 48rpx;
}

.symptom-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748b;
}

.symptom-name.selected {
  color: #1e293b;
  font-weight: bold;
}

/* Notes Section */
.notes-section {
  margin-bottom: 100rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.notes-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
}

.notes-input {
  width: 100%;
  height: 240rpx;
  font-size: 28rpx;
  color: #1e293b;
  background-color: #f8fafc;
  padding: 32rpx;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}

/* Footer */
.footer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 32rpx 60rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  z-index: 10;
}

.save-btn {
  width: 100% !important;
  background-color: #2F80ED !important;
  color: #ffffff !important;
  font-weight: bold !important;
  font-size: 34rpx !important;
  padding: 28rpx 0 !important;
  border-radius: 999rpx !important;
  box-shadow: 0 12rpx 24rpx rgba(47, 128, 237, 0.2) !important;
  border: none !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn:active {
  transform: scale(0.98);
  background-color: #2563eb !important;
}

.bottom-bar {
  width: 128rpx;
  height: 8rpx;
  background-color: #e2e8f0;
  margin: 40rpx auto 0;
  border-radius: 100rpx;
}

.occurrence-card {
  margin-top: 32rpx;
  padding: 28rpx;
  border: 2rpx solid #e7ebf0;
  border-radius: 24rpx;
  background: #fff;
}

.occurrence-title,
.occurrence-desc {
  display: block;
}

.occurrence-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 700;
}

.occurrence-desc {
  margin-top: 8rpx;
  color: #8b95a7;
  font-size: 22rpx;
  line-height: 1.5;
}

.occurrence-pickers {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.occurrence-pickers picker {
  flex: 1;
}

.occurrence-value {
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  background: #f4f7fb;
  color: #2563eb;
  font-size: 25rpx;
  font-weight: 650;
  text-align: center;
}
