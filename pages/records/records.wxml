<view class="records-page">
  <navigation-bar title="照护回顾" background="#fff" back="{{false}}"></navigation-bar>

  <scroll-view class="content-scroll" scroll-y enable-passive>
    <!-- Family Member Selector -->
    <view class="family-selector">
      <view 
        wx:for="{{familyMembers}}" 
        wx:key="id" 
        class="member-item {{item.active ? 'active' : ''}}" 
        bindtap="onSwitchMember" 
        data-id="{{item.id}}"
      >
        <view class="avatar-wrapper {{item.active ? 'border-primary' : ''}}">
          <image class="avatar" src="{{item.avatar}}" mode="aspectFill"></image>
        </view>
        <text class="member-name {{item.active ? 'text-primary' : ''}}">{{item.name}}</text>
      </view>
      <view class="add-member-btn" bindtap="onAddMember">
        <text class="plus-icon">+</text>
      </view>
    </view>

    <!-- Tabs -->
    <view class="tabs-container">
      <view 
        class="tab-btn {{activeTab === 'reminders' ? 'active' : ''}}" 
        bindtap="onTabChange" 
        data-tab="reminders"
      >事项</view>
      <view 
        class="tab-btn {{activeTab === 'weight' ? 'active' : ''}}" 
        bindtap="onTabChange" 
        data-tab="weight"
      >体重</view>
      <view 
        class="tab-btn {{activeTab === 'symptoms' ? 'active-rose' : ''}}" 
        bindtap="onTabChange" 
        data-tab="symptoms"
      >身体状态</view>
    </view>

    <view class="range-toolbar">
      <view class="range-options">
        <view
          wx:for="{{rangeOptions}}"
          wx:key="days"
          class="range-option {{selectedRangeDays === item.days ? 'active' : ''}}"
          bindtap="onRangeChange"
          data-days="{{item.days}}"
        >{{item.label}}</view>
      </view>
      <view class="record-action" bindtap="onAddRecord" data-tab="{{activeTab}}">
        {{activeTab === 'reminders' ? '添加事项' : (activeTab === 'weight' ? '记体重' : '记状态')}}
      </view>
    </view>

    <!-- Reminders Section -->
    <view class="stats-section" wx:if="{{activeTab === 'reminders'}}">
      <block wx:if="{{hasReminderData}}">
      <!-- Weekly Overview -->
      <view class="overview-card card-shadow">
        <view class="overview-info">
          <text class="overview-label">{{rangeLabel}}事项完成情况</text>
          <text class="overview-title">{{completionStatus}}</text>
          <view class="overview-stats">
            <text class="overview-desc">完成 <text class="num-highlight text-blue">{{weeklyCompletedTotal}}</text> 次</text>
            <text class="overview-desc-dot">·</text>
            <text class="overview-desc">计划 <text class="num-highlight text-gray">{{reminderTotal}}</text> 次</text>
          </view>
        </view>
        <view class="overview-progress">
          <view class="progress-circle-wrap">
            <view class="progress-circle-css" style="background: conic-gradient(#137fec {{reminderCompletion}}%, #f1f5f9 0);"></view>
            <view class="progress-circle-inner"></view>
            <view class="progress-content">
              <text class="progress-num">{{reminderCompletion}}</text>
              <text class="progress-unit">%</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Execution Trend -->
      <view class="trend-card">
        <view class="trend-header">
          <view class="trend-title-row">
            <text class="trend-icon-sm">📈</text>
            <text class="trend-title">执行趋势</text>
          </view>
          <text class="trend-period">{{rangeLabel}} · {{trendGranularity}}</text>
        </view>
        <view class="trend-legend">
          <view class="legend-item"><view class="legend-dot done"></view><text>已完成</text></view>
          <view class="legend-item"><view class="legend-dot planned"></view><text>计划次数</text></view>
        </view>
        <view class="trend-chart-container">
          <canvas
            canvas-id="trendChart"
            class="trend-canvas"
            style="width: {{trendCanvasCssW}}px; height: {{trendCanvasCssH}}px;"
            bindtouchstart="onTrendTouch"
          ></canvas>
        </view>
        <view class="trend-labels">
          <text wx:for="{{trendLabels}}" wx:key="*this" class="{{item === '今日' ? 'current' : ''}}">{{item}}</text>
        </view>
      </view>

      <!-- Missed Tasks -->
      <view class="missed-section" wx:if="{{missedReminders.length > 0}}">
        <view class="missed-header">
          <view>
            <view class="missed-title-row">
              <text class="missed-icon-sm">⚠️</text>
              <text class="missed-title">近48小时待确认</text>
            </view>
            <text class="missed-subtitle">请确认是否已完成或需要调整</text>
          </view>
          <view class="retry-btn" bindtap="onRetryTask">查看处理</view>
        </view>

        <view class="missed-item" wx:for="{{missedReminders}}" wx:key="id">
          <view class="missed-item-icon">
            <text class="material-icons">{{item.icon || 'medication'}}</text>
          </view>
          <view class="missed-item-content">
            <view class="missed-item-header">
              <text class="missed-item-name">{{item.name}}</text>
              <text class="missed-item-delay">超时 {{item.delay}}</text>
            </view>
            <text class="missed-item-time">计划时间: {{item.time}}</text>
          </view>
        </view>
      </view>
      <view class="all-clear-card" wx:else>
        <text class="all-clear-title">近48小时没有待确认事项</text>
        <text class="all-clear-desc">已完成的照护事项会继续保留在趋势中</text>
      </view>
      </block>

      <view class="empty-state" wx:else>
        <view class="empty-illustration blue">✓</view>
        <text class="empty-title">{{rangeLabel}}还没有事项记录</text>
        <text class="empty-desc">添加用药、复查或日常照护事项，完成后这里会生成执行回顾。</text>
        <view class="empty-action" bindtap="onAddRecord" data-tab="reminders">添加第一条事项</view>
      </view>
    </view>

    <!-- Weight Chart Section -->
    <view class="stats-section" wx:if="{{activeTab === 'weight'}}">
      <block wx:if="{{hasWeightData}}">
      <view class="chart-card">
        <view class="chart-header">
          <view>
            <text class="stat-label">最近一次体重</text>
            <view class="stat-value-row">
              <text class="stat-value">{{currentWeight}}</text>
              <text class="stat-unit">kg</text>
            </view>
          </view>
          <view class="trend-tag neutral" wx:if="{{weightRecordCount > 1}}">
            <text>{{rangeLabel}}变化 {{weightChangeLabel}}</text>
          </view>
        </view>
        
        <view class="chart-container" wx:if="{{weightTrendReady}}">
          <canvas id="weightChart" canvas-id="weightChart" type="2d" class="chart-canvas" bindtouchstart="onChartTouch"></canvas>
          <view class="chart-labels">
            <text wx:for="{{weightLabels}}" wx:key="*this" class="{{item === '今日' ? 'current' : ''}}">{{item}}</text>
          </view>
        </view>
        <view class="insufficient-data" wx:else>
          <text class="insufficient-title">继续记录后可查看趋势</text>
          <text class="insufficient-desc">当前有 {{weightRecordCount}} 条记录，至少需要 3 条。</text>
        </view>
      </view>

      <!-- History List -->
      <view class="history-section">
        <view class="section-header">
          <text class="section-title">历史记录</text>
          <!-- <text class="more-btn" bindtap="onViewMore">查看更多</text> -->
        </view>
        
        <view class="history-item" wx:for="{{history}}" wx:key="id">
          <view class="history-icon">
            <text class="icon-text">⚖️</text>
          </view>
          <view class="history-content">
            <view class="history-value-row">
              <text class="history-value">{{item.value}}</text>
              <text class="status-tag">{{item.status}}</text>
            </view>
            <text class="history-time">{{item.time}}{{item.note ? ' · ' + item.note : ''}}</text>
          </view>
        </view>

        <!-- Weekly Summary Card -->
        <view class="summary-card">
          <view class="summary-icon">📊</view>
          <view class="summary-content">
            <text class="summary-title">{{rangeLabel}}趋势简报</text>
            <text class="summary-text">{{trendSummary}}</text>
          </view>
        </view>
      </view>
      </block>

      <view class="empty-state" wx:else>
        <view class="empty-illustration green">kg</view>
        <text class="empty-title">{{rangeLabel}}还没有体重记录</text>
        <text class="empty-desc">记录第一次体重；累计 3 条后，这里会开始显示变化趋势。</text>
        <view class="empty-action green" bindtap="onAddRecord" data-tab="weight">记录体重</view>
      </view>
    </view>

    <!-- Symptoms Section -->
    <view class="stats-section" wx:if="{{activeTab === 'symptoms'}}">
      <block wx:if="{{hasSymptomData}}">
      <view class="chart-card">
        <view class="chart-header">
          <view>
            <text class="symptom-chart-title">身体状态出现天数</text>
            <text class="data-caption">共记录 {{symptomRecordCount}} 次</text>
          </view>
          <text class="stat-label">{{rangeLabel}}</text>
        </view>
        <view class="symptom-tag-cloud">
          <view 
            wx:for="{{symptomStats}}" 
            wx:key="name" 
            class="symptom-stat-tag tag-{{item.color}} {{item.count === 0 ? 'opacity-40' : ''}}"
          >
            <text class="symptom-tag-name">{{item.name}}</text>
            <text class="symptom-tag-count">{{item.countLabel}}</text>
          </view>
        </view>
      </view>

      <!-- Symptom History -->
      <view class="history-section">
        <view class="section-header">
          <text class="section-title">身体状态记录</text>
          <!-- <text class="more-btn text-rose">查看全部</text> -->
        </view>

        <view class="symptom-record-card" wx:for="{{symptomHistory}}" wx:key="id">
          <view class="card-accent"></view>
          <view class="record-header">
            <text class="record-time">{{item.time}}</text>
            <text class="severity-tag" wx:if="{{item.severity}}">{{item.severity}}</text>
          </view>
          <view class="record-tags">
            <view class="record-tag-item" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="name">
              <text class="tag-icon">{{tag.icon}}</text>
              <text class="tag-label">{{tag.name}}</text>
            </view>
          </view>
          <view class="record-note" wx:if="{{item.note}}">
            <text>{{item.note}}</text>
          </view>
        </view>
      </view>
      </block>

      <view class="empty-state" wx:else>
        <view class="empty-illustration rose">＋</view>
        <text class="empty-title">{{rangeLabel}}还没有身体状态记录</text>
        <text class="empty-desc">记录疼痛、发热、疲劳等情况，之后可以按出现天数回顾变化。</text>
        <view class="empty-action rose" bindtap="onAddRecord" data-tab="symptoms">记录身体状态</view>
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 底部导航 -->
  <tabbar activeTab="records" />
</view>
