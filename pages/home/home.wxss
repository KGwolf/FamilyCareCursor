/* pages/home/home.wxss */

/* Page Container */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9fafb;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  color: #111827;
  overflow: hidden;
}

.content-scroll {
  flex: 1;
  height: 0;
}

.tabbar-spacer {
  height: calc(160rpx + env(safe-area-inset-bottom) + 40rpx);
  width: 100%;
}

/* Header */
.header {
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(12px);
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.patient-selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background-color: #f9fafb;
  padding: 6rpx 18rpx 6rpx 6rpx;
  border-radius: 100rpx;
  border: 1rpx solid rgba(229, 231, 235, 0.5);
}

.add-member-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  border: 2rpx dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  flex-shrink: 0;
  margin-left: 24rpx;
  background-color: #f9fafb;
}

.plus-icon {
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.patient-info {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.patient-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  white-space: nowrap;
}

.patient-name {
  font-size: 26rpx;
  font-weight: 700;
  white-space: nowrap;
}

.dropdown-arrow {
  font-size: 30rpx !important;
  color: #9ca3af;
}

.switch-hint {
  font-size: 18rpx;
  color: #2563eb;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: -0.5rpx;
  white-space: nowrap;
}

.notification-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #eff6ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* Navigation Tabs */
.nav-tabs {
  display: flex;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
  background-color: #fff;
  gap: 48rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-item {
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #9ca3af;
  flex-shrink: 0;
}

.tab-active {
  font-weight: 700;
  color: #2563eb;
  border-bottom: 4rpx solid #2563eb;
}

/* Main Content */
.main-content {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  min-height: calc(100vh - 300rpx - env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* Tasks Header */
.tasks-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 16rpx 0;
  flex-shrink: 0;
}

/* Task Cards */
.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex: 1;
}

.empty-tasks {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  text-align: center;
  font-style: italic;
  line-height: 1.6;
}

.tasks-title-section {
  display: flex;
  flex-direction: column;
}

.tasks-title {
  font-size: 34rpx;
  font-weight: 800;
}

.tasks-date {
  margin-top: 2rpx;
  font-size: 22rpx;
  color: #6b7280;
  font-weight: 500;
}

.tasks-progress-section {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.progress-text {
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 700;
}

.progress-bar {
  width: 112rpx;
  height: 10rpx;
  background-color: #e5e7eb;
  border-radius: 100rpx;
  margin-top: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #2563eb;
  border-radius: 100rpx;
  transition: width 0.3s ease;
}

/* Task Cards */
.task-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.task-completed {
  background-color: rgba(37, 99, 235, 0.05);
  border: 1rpx solid rgba(37, 99, 235, 0.1);
}

.task-important {
  border: 2rpx solid rgba(37, 99, 235, 0.2);
}

.task-icon-wrapper {
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.icon-completed {
  background-color: #fff !important;
}

.icon-bg-white {
  background-color: #fff;
}

.icon-bg-sky {
  background-color: #e0f2fe;
}

.icon-bg-amber {
  background-color: #fef3c7;
}

.icon-bg-purple {
  background-color: #f3e8ff;
}

/* Task Icon Style */
.task-icon {
  font-family: 'Material Icons';
  font-size: 34rpx;
}

.task-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.task-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.important-tag {
  flex-shrink: 0;
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  background: #eaf2ff;
  color: #2563eb;
  font-size: 18rpx;
  font-weight: 700;
}

.task-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #111827;
}

.title-completed {
  font-weight: 500;
  color: #9ca3af;
  text-decoration: line-through;
}

.task-subtitle {
  font-size: 21rpx;
  color: #6b7280;
  display: flex;
  align-items: center;
}

.subtitle-success {
  color: #2563eb;
  font-weight: 700;
}

.subtitle-note {
  color: #9ca3af;
  font-weight: 400;
}

.task-status {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-completed {
  background-color: #2563eb;
}

.status-pending {
  border: 3rpx solid #d1d5db;
  background-color: transparent;
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.delete-btn {
  width: 40rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  margin-left: 0;
  flex-shrink: 0;
}

.delete-btn:active {
  color: #ef4444;
}

.delete-btn .material-icons {
  font-size: 36rpx;
}

/* Motivation Card */
.motivation-card {
  margin-top: 24rpx;
  padding: 48rpx;
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  border-radius: 48rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
}

.motivation-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.motivation-title {
  font-size: 36rpx;
  font-weight: 700;
}

.motivation-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.motivation-btn {
  display: block;
  width: fit-content;
  padding: 16rpx 40rpx;
  margin-top: 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 700;
  backdrop-filter: blur(8px);
  position: relative;
  z-index: 2;
}

.motivation-btn:active {
  background-color: rgba(255, 255, 255, 0.3);
}

.motivation-bg-circle {
  position: absolute;
  bottom: -64rpx;
  right: -64rpx;
  width: 256rpx;
  height: 256rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  filter: blur(40rpx);
}

/* Action-first home V1 */
.header-actions {
  display: flex;
  gap: 10rpx;
  margin-left: auto;
}

.header-action {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
  color: #526079;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.header-action-icon { font-size: 30rpx !important; }

.welcome-line {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.welcome-heading {
  font-size: 40rpx;
  font-weight: 800;
}

.welcome-date {
  color: #7b8495;
  font-size: 24rpx;
}

.quick-section,
.tasks-section-v1,
.upcoming-section,
.recent-section {
  padding: 28rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 8rpx 30rpx rgba(31, 41, 55, 0.05);
}

.tasks-section-v1 { overflow: hidden; }

.schedule-card {
  color: #fff;
  background: linear-gradient(135deg, #2468dd, #4b8df8);
}

.section-label {
  color: rgba(255, 255, 255, 0.76);
  font-size: 22rpx;
}

.schedule-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 20rpx;
}

.schedule-title,
.schedule-date,
.schedule-note {
  display: block;
}

.schedule-title {
  font-size: 36rpx;
  font-weight: 750;
}

.schedule-date {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.countdown-tag {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 100rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  font-weight: 700;
}

.schedule-note {
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.schedule-empty {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 27rpx;
}

.section-title-small {
  display: block;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 750;
}

.quick-grid {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
  width: 100%;
}

.quick-item {
  flex: 1;
  min-width: 0;
  box-sizing: border-box;
  padding: 20rpx 4rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 23rpx;
  font-weight: 650;
}

.quick-item:active {
  transform: scale(0.97);
}

.quick-icon {
  font-size: 34rpx !important;
  font-weight: 800;
}

.quick-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 2rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(31, 41, 55, 0.05);
}

.quick-blue { color: #2563eb; background: #edf4ff; }
.quick-orange { color: #df6624; background: #fff3eb; }
.quick-green { color: #168a50; background: #ebf8f0; }

.section-heading-row {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.upcoming-heading {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.upcoming-heading-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: #eaf2ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.upcoming-heading-copy { min-width: 0; display: flex; flex-direction: column; }

.section-title-inline {
  color: #172033;
  font-size: 30rpx;
  font-weight: 750;
}

.section-caption {
  margin-top: 4rpx;
  color: #9aa3b2;
  font-size: 20rpx;
  white-space: nowrap;
}

.calendar-link {
  flex-shrink: 0;
  padding: 8rpx 0 8rpx 20rpx;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 650;
}

.upcoming-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.upcoming-item {
  min-height: 104rpx;
  box-sizing: border-box;
  padding: 18rpx;
  border: 2rpx solid #eef2f7;
  border-radius: 24rpx;
  background: #fafbfd;
  display: flex;
  align-items: center;
}

.upcoming-item:active { background: #f2f6fb; transform: scale(0.99); }

.upcoming-date-card {
  width: 112rpx;
  min-height: 80rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #eef5ff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upcoming-day,
.upcoming-time,
.upcoming-title,
.upcoming-note { display: block; }

.upcoming-day { color: #2563eb; font-size: 23rpx; font-weight: 750; }
.upcoming-time { margin-top: 5rpx; color: #6684b1; font-size: 20rpx; }
.upcoming-copy { flex: 1; min-width: 0; margin-left: 20rpx; }
.upcoming-title-row { display: flex; align-items: center; gap: 10rpx; }
.upcoming-type-icon { color: #5d6b80; font-size: 26rpx; }
.upcoming-title { color: #172033; font-size: 27rpx; font-weight: 700; }
.upcoming-note { margin-top: 6rpx; color: #8a94a5; font-size: 22rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.upcoming-arrow { margin-left: 16rpx; color: #b5bdc9; font-size: 40rpx; }

.more-tasks-wrap {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e9eef5;
}

.more-tasks {
  width: 100%;
  height: 58rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  margin-top: 0;
  padding: 0 16rpx;
  border-radius: 18rpx;
  background: #f4f7fc;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 650;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.more-arrow { margin-left: 6rpx; font-size: 30rpx; line-height: 1; }

.tasks-section-v1 .tasks-header {
  padding-top: 0;
  padding-bottom: 12rpx;
}

.tasks-section-v1 .tasks-list { flex: none; }

.compact-empty {
  padding: 28rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
  color: #7f899a;
  font-size: 25rpx;
  text-align: center;
}

.inline-add {
  margin-top: 14rpx;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
}

.schedule-empty .inline-add {
  margin-top: 0;
  color: #fff;
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf0f4;
}

.recent-item:last-child {
  border-bottom: 0;
}

.recent-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recent-copy {
  flex: 1;
  min-width: 0;
}

.recent-title,
.recent-time {
  display: block;
}

.recent-title {
  font-size: 27rpx;
  font-weight: 700;
}

.recent-time {
  margin-top: 6rpx;
  color: #8a94a5;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.left-empty {
  line-height: 1.6;
  text-align: left;
}
