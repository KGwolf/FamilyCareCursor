<view class="page-container">
  <navigation-bar back="{{false}}" title="今天" color="black" background="#FFF"></navigation-bar>

  <scroll-view class="content-scroll" scroll-y show-scrollbar="{{false}}">
    <view class="header">
      <view class="patient-selector" bindtap="onSwitchPatient">
        <image class="avatar" src="{{currentPatient.avatar}}" mode="aspectFill"></image>
        <view class="patient-info">
          <view class="patient-name-row">
            <text class="patient-name">{{currentPatient.name}}</text>
            <text class="material-icons dropdown-arrow">expand_more</text>
          </view>
        </view>
      </view>
      <view class="header-actions">
        <view class="header-action" bindtap="onAddMember" aria-role="button" aria-label="添加家人">
          <text class="material-icons header-action-icon">person_add</text>
        </view>
        <view class="header-action" bindtap="onOpenSettings" aria-role="button" aria-label="设置">
          <text class="material-icons header-action-icon">settings</text>
        </view>
      </view>
    </view>

    <view class="main-content">
      <view class="quick-section">
        <text class="section-title-small">常用记录</text>
        <view class="quick-grid">
          <view class="quick-item quick-blue" bindtap="onQuickAction" data-action="item">
            <view class="quick-icon-wrap"><text class="material-icons quick-icon">add_task</text></view>
            <text>添加事项</text>
          </view>
          <view class="quick-item quick-orange" bindtap="onQuickAction" data-action="symptoms">
            <view class="quick-icon-wrap"><text class="material-icons quick-icon">monitor_heart</text></view>
            <text>身体状态</text>
          </view>
          <view class="quick-item quick-green" bindtap="onQuickAction" data-action="weight">
            <view class="quick-icon-wrap"><text class="material-icons quick-icon">monitor_weight</text></view>
            <text>体重</text>
          </view>
        </view>
      </view>

      <view class="tasks-section-v1">
        <view class="tasks-header">
          <view class="tasks-title-section">
            <text class="tasks-title">今日事项</text>
            <text class="tasks-date">完成 {{completedTasks}}/{{totalTasks}}</text>
          </view>
          <view class="progress-bar"><view class="progress-fill" style="width: {{progressPercent}}%"></view></view>
        </view>

        <view class="tasks-list">
          <block wx:if="{{tasks.length > 0}}">
            <block wx:for="{{tasks}}" wx:key="id">
              <view wx:if="{{index < 3}}" class="task-card {{item.completed ? 'task-completed' : ''}} {{item.important ? 'task-important' : ''}}" bindtap="onTaskTap" data-id="{{item.id}}">
                <view class="task-icon-wrapper {{item.completed ? 'icon-completed' : ''}} {{item.iconBg}}">
                  <text class="task-icon material-icons">{{item.icon}}</text>
                </view>
                <view class="task-content">
                  <view class="task-title-row">
                    <text class="task-title {{item.completed ? 'title-completed' : ''}}">{{item.time}}  {{item.title}}</text>
                    <text wx:if="{{item.important && !item.completed}}" class="important-tag">重要</text>
                  </view>
                  <text class="task-subtitle">{{item.completed ? '已完成' : (item.location || '点击标记完成')}}</text>
                </view>
                <view class="task-status {{item.completed ? 'status-completed' : 'status-pending'}}">
                  <text wx:if="{{item.completed}}" class="check-icon">✓</text>
                </view>
                <view class="delete-btn" catchtap="onDeleteTask" data-id="{{item.id}}">×</view>
              </view>
            </block>
          </block>
          <view wx:else class="compact-empty">
            <text>今天还没有事项</text>
          </view>
        </view>
        <view wx:if="{{hiddenTasksCount > 0}}" class="more-tasks-wrap">
          <view class="more-tasks" bindtap="onOpenCalendar">
            <text>还有 {{hiddenTasksCount}} 项，查看全部</text>
            <text class="more-arrow">›</text>
          </view>
        </view>
      </view>

      <view class="upcoming-section" wx:if="{{upcomingItems.length > 0}}">
        <view class="section-heading-row">
          <view class="upcoming-heading">
            <view class="upcoming-heading-icon">日</view>
            <view class="upcoming-heading-copy">
              <text class="section-title-inline">接下来</text>
              <text class="section-caption">未来事项</text>
            </view>
          </view>
          <view class="calendar-link" bindtap="onOpenCalendar">查看日历 ›</view>
        </view>
        <view class="upcoming-list">
          <view
            wx:for="{{upcomingItems}}"
            wx:key="id"
            class="upcoming-item"
            bindtap="onOpenCalendar"
            data-date="{{item.date}}"
          >
            <view class="upcoming-date-card">
              <text class="upcoming-day">{{item.dateLabel}}</text>
              <text class="upcoming-time">{{item.time}}</text>
            </view>
            <view class="upcoming-copy">
              <view class="upcoming-title-row">
                <text class="material-icons upcoming-type-icon">{{item.icon}}</text>
                <text class="upcoming-title">{{item.title}}</text>
              </view>
              <text class="upcoming-note" wx:if="{{item.remark}}">{{item.remark}}</text>
            </view>
            <text class="upcoming-arrow">›</text>
          </view>
        </view>
      </view>

      <view class="recent-section">
        <text class="section-title-small">最近变化</text>
        <view wx:if="{{recentChanges.length > 0}}" class="recent-list">
          <view wx:for="{{recentChanges}}" wx:key="id" class="recent-item">
            <view class="recent-icon">{{item.icon}}</view>
            <view class="recent-copy">
              <text class="recent-title">{{item.title}}</text>
              <text class="recent-time">{{item.time}}{{item.note ? ' · ' + item.note : ''}}</text>
            </view>
          </view>
        </view>
        <view wx:else class="compact-empty left-empty">记下第一条身体状态或体重，以后回顾会更清楚。</view>
      </view>
    </view>

    <view class="tabbar-spacer"></view>
  </scroll-view>
  <tabbar activeTab="home" />
</view>
