<navigation-bar id="navigationBar" title="新建提醒" color="black" background="#F8FAFC"></navigation-bar>

<view class="page-container">
  <scroll-view class="main-content" scroll-y="true">
    
    <!-- 当前对象卡片 -->
    <view class="card target-section">
      <view class="target-info">
        <image class="target-avatar" src="{{currentTarget.avatar || '/images/user1.png'}}" mode="aspectFill"></image>
        <view class="target-details">
          <view class="target-name-row">
            <text class="target-name">{{currentTarget.name}}</text>
            <text class="target-badge">当前对象</text>
          </view>
          <!-- <text class="target-desc">正在为{{currentTarget.name}}设置提醒</text> -->
        </view>
      </view>
      <view class="switch-btn" bindtap="onSwitchTarget">
        <text class="material-icons">swap_horiz</text>
        <text class="switch-text">切换</text>
      </view>
    </view>

    <!-- 提醒类型 -->
    <view class="form-group">
      <label class="group-label">提醒类型</label>
      <view class="input-wrapper">
        <text class="material-icons input-icon">{{reminderTypes[selectedTypeIndex].icon}}</text>
        <picker bindchange="onSelectType" value="{{selectedTypeIndex}}" range="{{reminderTypes}}" range-key="name" class="full-picker" confirm-color="#2F80ED">
          <view class="inp-like">
            <text>{{reminderTypes[selectedTypeIndex].name}}</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 时间与周期 -->
    <view class="form-group">
      <text class="group-sublabel">时间与周期</text>
      <view class="time-grid">
        <picker mode="time" value="{{selectedTime}}" bindchange="onTimeChange" class="time-card-wrapper" confirm-color="#2F80ED">
          <view class="card time-card">
            <text class="card-tag">执行时间</text>
            <view class="card-value primary-text">
              <text class="material-icons">schedule</text>
              <text>{{selectedTime}}</text>
            </view>
          </view>
        </picker>
        
        <view class="card time-card" wx:if="{{frequencyOptions[selectedFreqIndex].value === 'custom'}}">
          <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange" class="full-picker" confirm-color="#2F80ED">
            <text class="card-tag">选择日期</text>
            <view class="card-value">
              <text class="material-icons">event</text>
              <text>{{selectedDate || '点击选择'}}</text>
            </view>
          </picker>
        </view>
        <view class="card time-card" wx:else>
          <text class="card-tag">重复频率</text>
          <view class="card-value">
            <text class="material-icons primary-text">event_repeat</text>
            <text>{{frequencyOptions[selectedFreqIndex].name}}一次</text>
          </view>
        </view>
      </view>

      <view class="freq-tabs">
        <view 
          wx:for="{{frequencyOptions}}" 
          wx:key="index"
          class="tab-btn {{selectedFreqIndex === index ? 'active' : ''}}"
          bindtap="onFreqSelect"
          data-index="{{index}}"
        >
          {{item.name}}
        </view>
      </view>
    </view>

    <!-- 备注信息 -->
    <view class="form-group">
      <label class="group-label">备注信息 (可选)</label>
      <textarea 
        class="inp remark-textarea"
        placeholder="例如：饭后半小时服用..."
        value="{{remark}}"
        bindinput="onRemarkInput"
        maxlength="200"
      ></textarea>
    </view>

  </scroll-view>

  <!-- Footer -->
  <view class="footer-bar">
    <button class="confirm-btn" bindtap="onSubmit">
      <text class="material-icons">check_circle</text>
      确认添加提醒
    </button>
  </view>
</view>
