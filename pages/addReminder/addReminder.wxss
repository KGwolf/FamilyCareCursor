/* pages/addReminder/addReminder.wxss */

page {
  height: 100%;
  background-color: #F8FAFC;
  color: #1E293B;
  font-family: 'Lexend', 'Noto Sans SC', sans-serif;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.main-content {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 240rpx;
  box-sizing: border-box;
}

/* Common Card Style */
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  border: 2rpx solid #F1F5F9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 32rpx;
  padding: 32rpx;
  transition: all 0.2s ease;
}

.card:active {
  background-color: #F8FAFC;
}

/* Target Section */
.target-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.target-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
  min-width: 0; /* 允许子元素缩放 */
}

.target-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  border: 4rpx solid rgba(47, 128, 237, 0.1);
  background-color: #F1F5F9;
  flex-shrink: 0;
}

.target-details {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.target-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
  flex-wrap: nowrap; /* 禁止换行 */
}

.target-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200rpx;
}

.target-badge {
  background: rgba(47, 128, 237, 0.1);
  color: #2F80ED;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 700;
  white-space: nowrap; /* 禁止换行 */
  flex-shrink: 0;
}

.target-desc {
  font-size: 26rpx;
  color: #64748B;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.switch-btn {
  display: flex;
  align-items: center;
  flex-direction: column; /* 图标文字垂直排布，如果需要水平可改回 row */
  justify-content: center;
  gap: 4rpx;
  color: #2F80ED;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  padding-left: 20rpx;
  border-left: 2rpx solid #F1F5F9;
}

.switch-text {
  white-space: nowrap;
}

/* Form Groups */
.form-group {
  margin-bottom: 40rpx;
}

.group-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #334155;
  margin-left: 8rpx;
  margin-bottom: 16rpx;
}

.group-sublabel {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #94A3B8;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-left: 8rpx;
  margin-bottom: 24rpx;
}

.input-wrapper {
  position: relative;
  width: 100%;
}

.inp {
  width: 100%;
  background: #FFFFFF;
  border: 2rpx solid #E2E8F0;
  border-radius: 32rpx;
  padding: 32rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.inp-like {
  width: 100%;
  background: #FFFFFF;
  border: 2rpx solid #E2E8F0;
  border-radius: 32rpx;
  padding: 32rpx 32rpx 32rpx 88rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  min-height: 104rpx;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #2F80ED;
  z-index: 2;
}

.remark-textarea {
  min-height: 240rpx;
  padding: 32rpx;
}

/* Time Grid */
.time-grid {
  display: flex; /* 改用 flex 确保在 picker 包裹下也能正常分列 */
  gap: 24rpx;
  margin-bottom: 32rpx;
  width: 100%;
}

.time-card-wrapper, .time-grid > .card {
  flex: 1;
  min-width: 0;
}

.time-card {
  margin-bottom: 0 !important; /* 强制移除底部间距 */
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 8rpx;
  text-align: center;
  height: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.card-tag {
  font-size: 20rpx;
  color: #94A3B8;
  margin-bottom: 8rpx;
  white-space: nowrap;
}

.card-value {
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 8rpx;
  white-space: nowrap;
}

.primary-text {
  color: #2F80ED;
  font-size: 40rpx;
}

/* Frequency Tabs */
.freq-tabs {
  display: flex;
  gap: 16rpx;
}

.tab-btn {
  padding: 16rpx 40rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
  background: #FFFFFF;
  border: 2rpx solid #E2E8F0;
  color: #64748B;
  transition: all 0.2s;
}

.tab-btn.active {
  background: #2F80ED;
  border-color: #2F80ED;
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(47, 128, 237, 0.2);
}

/* Footer & Button */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 48rpx 32rpx;
  background: linear-gradient(to top, #F8FAFC, rgba(248, 250, 252, 0.95), transparent);
  z-index: 100;
}

.confirm-btn {
  width: 100% !important;
  background: #2F80ED !important;
  color: #FFFFFF !important;
  font-size: 32rpx !important;
  font-weight: 700 !important;
  padding: 28rpx 0 !important;
  border-radius: 32rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 16rpx !important;
  border: none !important;
  box-shadow: 0 16rpx 40rpx rgba(47, 128, 237, 0.3) !important;
}

.confirm-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}
