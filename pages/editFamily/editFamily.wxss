/* pages/editFamily/editFamily.wxss */
.page-container {
  height: 100vh;
  background-color: #F8F9FB;
}

.content-wrapper {
  padding: 20rpx 40rpx 240rpx;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 48rpx;
  padding: 48rpx 48rpx 64rpx;
  margin-top: 16rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid #F0F2F5;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
  overflow: hidden;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
  position: relative;
}

.delete-top-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #EF4444;
  padding: 8rpx 24rpx;
  background-color: #FFF5F5;
  border-radius: 100rpx;
  border: 1rpx solid #FEE2E2;
  z-index: 20;
}

.delete-top-btn:active {
  opacity: 0.7;
  background-color: #FEE2E2;
}

.avatar-container {
  position: relative;
  width: 192rpx;
  height: 192rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #f3f4f6;
  background-size: cover;
  background-position: center;
  border: 8rpx solid #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  box-sizing: border-box;
}

.avatar-edit-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 64rpx;
  height: 64rpx;
  background-color: #2F80ED;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
  padding: 0;
  z-index: 10;
}

.camera-icon {
  font-size: 28rpx;
  color: #ffffff;
}

.avatar-hint {
  font-size: 24rpx;
  color: #70777F;
  font-weight: 500;
  margin-top: 24rpx;
}

/* 表单部分 */
.form-section {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #44474E;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  background-color: #F8F9FB;
  border: 1rpx solid #F0F2F5;
  border-radius: 24rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
  height: 96rpx;
  line-height: 96rpx;
}

.form-input-focus {
  background-color: #ffffff;
  border-color: #2F80ED;
}

/* 关系选择 */
.relation-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 40rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  background-color: #F8F9FB;
  color: #70777F;
  border: 1rpx solid #F0F2F5;
  transition: all 0.2s ease;
}

.tag-active {
  background-color: #2F80ED;
  color: #ffffff;
  font-weight: 700;
  border-color: #2F80ED;
}

/* 年龄和性别行 */
.form-row {
  display: flex;
  gap: 32rpx;
}

.age-item {
  flex: 1;
}

.gender-item {
  flex: 1;
}

/* 性别选择 */
.gender-toggle {
  display: flex;
  background-color: #F8F9FB;
  padding: 8rpx;
  border-radius: 24rpx;
  border: 1rpx solid #F0F2F5;
  height: 96rpx;
  box-sizing: border-box;
}

.gender-btn {
  flex: 1;
  font-size: 26rpx;
  text-align: center;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  color: #70777F;
  font-weight: 500;
  background-color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gender-btn.active {
  background-color: #2F80ED;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(47, 128, 237, 0.2);
}

/* 文本域 */
.form-textarea {
  width: 100%;
  background-color: #F8F9FB;
  border: 1rpx solid #F0F2F5;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  min-height: 200rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
  line-height: 1.5;
}

/* 底部保存按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-top: 1rpx solid #F0F2F5;
  padding: 32rpx 48rpx 64rpx;
  z-index: 100;
}

.save-btn {
  width: 100% !important;
  background-color: #2F80ED;
  color: #ffffff;
  font-weight: 700;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(47, 128, 237, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn:active {
  transform: scale(0.98);
}
