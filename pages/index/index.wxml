<page-meta>
  <navigation-bar title="家人照护记" color="black" background="#F7F8FA"></navigation-bar>
</page-meta>

<view class="page-container">
  <view class="intro">
    <view class="brand-mark">❤</view>
    <text class="welcome-title">今天想先做什么？</text>
    <text class="welcome-desc">先记下一件有用的事，家人资料稍后再完善</text>
  </view>

  <view class="action-list">
    <view
      wx:for="{{actions}}"
      wx:key="id"
      class="action-card"
      bindtap="onActionTap"
      data-action="{{item.id}}"
    >
      <view class="action-icon {{item.tone}}">{{item.icon}}</view>
      <view class="action-copy">
        <text class="action-title">{{item.title}}</text>
        <text class="action-desc">{{item.desc}}</text>
      </view>
      <text class="action-arrow">›</text>
    </view>
  </view>

  <text class="privacy-text">信息仅保存在当前设备</text>
</view>

<view class="picker-mask" wx:if="{{showRelationPicker}}" bindtap="closeRelationPicker">
  <view class="picker-panel" catchtap="preventClose">
    <view class="picker-handle"></view>
    <text class="picker-title">这是为谁记录？</text>
    <text class="picker-desc">点一下即可开始，姓名和年龄以后再填</text>
    <view class="relation-grid">
      <view
        wx:for="{{relations}}"
        wx:key="value"
        class="relation-item"
        bindtap="onRelationTap"
        data-relation="{{item.value}}"
      >
        <image class="relation-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>
</view>
