page {
  min-height: 100%;
  background: #f7f8fa;
  color: #172033;
}

.page-container {
  height: 100vh;
  min-height: 0;
  box-sizing: border-box;
  padding: 128rpx 32rpx 56rpx;
  display: flex;
  flex-direction: column;
}

.intro {
  margin-bottom: 48rpx;
}

.brand-mark {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 32rpx;
  border-radius: 24rpx;
  background: #eaf2ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.welcome-title,
.welcome-desc,
.action-title,
.action-desc,
.privacy-text,
.picker-title,
.picker-desc {
  display: block;
}

.welcome-title {
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 750;
}

.welcome-desc {
  margin-top: 16rpx;
  color: #768196;
  font-size: 28rpx;
  line-height: 1.6;
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-card {
  min-height: 124rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #fff;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(31, 41, 55, 0.05);
}

.action-card:active {
  transform: scale(0.985);
  background: #fafbfc;
}

.action-icon {
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.action-icon.blue { background: #eaf2ff; color: #2563eb; }
.action-icon.orange { background: #fff1e8; color: #e66b24; }
.action-icon.green { background: #e9f8ef; color: #168a50; }
.action-icon.purple { background: #f2edff; color: #7357c9; }

.action-copy {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.action-title {
  font-size: 30rpx;
  font-weight: 700;
}

.action-desc {
  margin-top: 8rpx;
  color: #8992a3;
  font-size: 24rpx;
}

.action-arrow {
  color: #b7bfcc;
  font-size: 48rpx;
  margin-left: 16rpx;
}

.privacy-text {
  margin-top: auto;
  padding-top: 32rpx;
  text-align: center;
  color: #a3aab7;
  font-size: 22rpx;
}

.picker-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  background: rgba(17, 24, 39, 0.42);
}

.picker-panel {
  width: 100%;
  flex-shrink: 0;
  box-sizing: border-box;
  padding: 20rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  border-radius: 40rpx 40rpx 0 0;
  background: #fff;
}

.picker-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 36rpx;
  border-radius: 8rpx;
  background: #d8dde6;
}

.picker-title {
  font-size: 38rpx;
  font-weight: 750;
  text-align: center;
}

.picker-desc {
  margin-top: 12rpx;
  color: #8791a3;
  font-size: 24rpx;
  text-align: center;
}

.relation-grid {
  margin-top: 36rpx;
  display: flex;
  align-items: flex-start;
  width: 100%;
}

.relation-item {
  width: 20%;
  flex: 0 0 20%;
  box-sizing: border-box;
  padding: 20rpx 4rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
}

.relation-item:active {
  background: #f1f5f9;
}

.relation-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #eef2f7;
}
