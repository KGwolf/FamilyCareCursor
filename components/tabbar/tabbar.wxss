/* components/tabbar/tabbar.wxss */

.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid #f3f0e7;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 50;
  transition: all 0.3s ease;
}

/* 暗色模式 */
.tabbar.dark {
  background: rgba(34, 29, 16, 0.95);
  border-top: 1rpx solid #3d3624;
}

.tabbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 112rpx; /* 14 * 8 */
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #9ca3af; /* text-gray-400 */
  position: relative;
}

.icon-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
}

.icon-svg {
  width: 24px;
  height: 24px;
  fill: currentColor;
  transition: fill 0.2s ease;
}

.icon-image {
  width: 24px;
  height: 24px;
  transition: all 0.2s ease;
}

.add-button .icon-image {
  width: 28px;
  height: 28px;
}

.tab-item.active {
  color: #2563eb; /* text-primary */
}

.tab-item.active .label {
  font-weight: bold;
}

.label {
  font-size: 20rpx; /* text-[10px] */
  margin-top: 4rpx; /* mt-0.5 */
  font-weight: 500;
}

/* 中间大按钮样式 */
.add-tab {
  overflow: visible;
}

.add-button-wrap {
  position: absolute;
  top: -48rpx; /* -top-6 * 8 */
  width: 96rpx; /* w-12 * 8 */
  height: 96rpx;
  background: #2563eb; /* bg-primary */
  border-radius: 50%;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #f8f8f6; /* ring-4 */
}

.dark .add-button-wrap {
  border-color: #221d10; /* ring-background-dark */
}

.add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.mt-record {
  margin-top: 56rpx; /* mt-7 * 8 */
}

.filled {
  /* SVG 填充逻辑通常通过 path 切换或 CSS 变量，这里简单处理 */
}

/* Modal Styles */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10rpx);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  animation: fadeIn 0.3s ease;
}

.modal-container {
  width: 100%;
  max-width: 375px;
  padding: 18rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  box-shadow: 0 -20rpx 60rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  animation: slideUp 0.3s ease;
  box-sizing: border-box;
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #dbe0e8;
}

.modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 750;
  color: #0f172a;
  line-height: 1.3;
}

.modal-subtitle {
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 23rpx;
}

.modal-grid {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  width: 100%;
}

.item-entry {
  width: 100%;
  box-sizing: border-box;
  padding: 26rpx;
  border: 2rpx solid #d9e8ff;
  border-radius: 26rpx;
  background: #f8fbff;
  display: flex;
  align-items: center;
  transition: transform 0.1s, background-color 0.1s;
}

.item-entry:active { background: #eff6ff; transform: scale(0.99); }
.item-icon { width: 84rpx !important; height: 84rpx !important; flex-shrink: 0; }
.entry-copy { flex: 1; margin-left: 24rpx; display: flex; flex-direction: column; }
.entry-title { color: #172033; font-size: 30rpx; font-weight: 700; }
.entry-desc { margin-top: 8rpx; color: #788397; font-size: 22rpx; line-height: 1.45; }
.entry-arrow { margin-left: 12rpx; color: #9aa8bb; font-size: 48rpx; line-height: 1; }
.record-heading { width: 100%; margin: 34rpx 0 20rpx; display: flex; flex-direction: column; }
.record-title { color: #172033; font-size: 28rpx; font-weight: 700; }
.record-desc { margin-top: 6rpx; color: #94a3b8; font-size: 22rpx; }

.modal-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
  padding: 24rpx;
  border: 2rpx solid #edf0f5;
  border-radius: 26rpx;
  background: #fafbfd;
  transition: transform 0.1s, background-color 0.1s;
  flex: 1;
  min-width: 0;
}

.modal-button:active {
  transform: scale(0.98);
  background: #f3f6fa;
}

.modal-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
}

.modal-icon.blue {
  background-color: #eff6ff;
  color: #3b82f6;
}

.modal-icon.green {
  background-color: #f0fdf4;
  color: #10b981;
}

.modal-icon.orange {
  background-color: #fff7ed;
  color: #f97316;
}

.modal-icon.purple {
  background-color: #f3efff;
  color: #7357c9;
}

.modal-label {
  margin-top: 20rpx;
  font-size: 27rpx;
  font-weight: 700;
  color: #273449;
}

.modal-card-desc {
  margin-top: 6rpx;
  color: #97a1b1;
  font-size: 21rpx;
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background-color: #f1f4f8;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.1s, background-color 0.1s;
}

.modal-close:active {
  transform: scale(0.94);
  background-color: #e7ebf1;
}

.close-icon {
  color: #7d8999;
  font-size: 38rpx;
  font-weight: 400;
  line-height: 1;
}

/* Animations */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* Dark Mode Support */
.modal-overlay.dark .modal-container {
  background-color: #1e293b;
}

.modal-overlay.dark .modal-title,
.modal-overlay.dark .record-title,
.modal-overlay.dark .entry-title,
.modal-overlay.dark .modal-label {
  color: #f8fafc;
}

.modal-overlay.dark .item-entry,
.modal-overlay.dark .modal-button {
  border-color: #34445a;
  background: #263449;
}

.modal-overlay.dark .modal-icon.blue {
  background-color: rgba(59, 130, 246, 0.2);
}

.modal-overlay.dark .modal-icon.green {
  background-color: rgba(16, 185, 129, 0.2);
}

.modal-overlay.dark .modal-icon.orange {
  background-color: rgba(249, 115, 22, 0.2);
}

.modal-overlay.dark .modal-close {
  background-color: #334155;
}

.modal-overlay.dark .close-icon {
  color: #94a3b8;
}
