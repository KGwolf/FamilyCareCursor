<!-- components/tabbar/tabbar.wxml -->
<view class="tabbar-placeholder"></view>
<view class="tabbar {{isDark ? 'dark' : ''}}">
  <view class="tabbar-inner">
    <!-- 首页 -->
    <view class="tab-item {{activeTab === 'home' ? 'active' : ''}}" bindtap="onTabChange" data-tab="home" data-url="/pages/home/home">
      <view class="icon-container">
        <image class="icon-image" src="{{activeTab === 'home' ? '/images/home_active.png' : '/images/home.png'}}" mode="aspectFill"></image>
      </view>
      <text class="label">首页</text>
    </view>

    <!-- 日程 -->
    <view class="tab-item {{activeTab === 'calendar' ? 'active' : ''}}" bindtap="onTabChange" data-tab="calendar" data-url="/pages/calendar/calendar">
      <view class="icon-container">
        <image class="icon-image" src="{{activeTab === 'calendar' ? '/images/calender_active.png' : '/images/calender.png'}}" mode="aspectFill"></image>
      </view>
      <text class="label">日程</text>
    </view>

    <!-- 记录 (中心大按钮) -->
    <view class="tab-item add-tab" bindtap="showAddModal">
      <view class="add-button-wrap">
        <view class="add-button">
          <image class="icon-image" src="/images/addRecord_big.png" mode="aspectFill"></image>
        </view>
      </view>
      <text class="label mt-record">记录</text>
    </view>

    <!-- 档案 -->
    <view class="tab-item {{activeTab === 'records' ? 'active' : ''}}" bindtap="onTabChange" data-tab="records" data-url="/pages/records/records">
      <view class="icon-container">
        <image class="icon-image" src="{{activeTab === 'records' ? '/images/record_active.png' : '/images/record.png'}}" mode="aspectFill"></image>
      </view>
      <text class="label">档案</text>
    </view>

    <!-- 设置 -->
    <view class="tab-item {{activeTab === 'settings' ? 'active' : ''}}" bindtap="onTabChange" data-tab="settings" data-url="/pages/settings/settings">
      <view class="icon-container">
        <image class="icon-image" src="{{activeTab === 'settings' ? '/images/setting_active.png' : '/images/setting.png'}}" mode="aspectFill"></image>
      </view>
      <text class="label">设置</text>
    </view>
  </view>
</view>

<!-- Add Record Modal -->
<view class="modal-overlay" wx:if="{{showAddModal}}" catchtap="hideAddModal">
  <view class="modal-container" catchtap="noop">
    <view class="modal-title">想要记录什么？</view>
    <view class="modal-grid">
      <view class="modal-button" bindtap="navigateToReminder">
        <view class="modal-icon blue">
          <text class="icon">🔔</text>
        </view>
        <view class="modal-label">加提醒</view>
      </view>
      <view class="modal-button" bindtap="navigateToWeight">
        <view class="modal-icon green">
          <text class="icon">⚖️</text>
        </view>
        <view class="modal-label">记体重</view>
      </view>
      <view class="modal-button" bindtap="navigateToSymptoms">
        <view class="modal-icon orange">
          <text class="icon">❤️</text>
        </view>
        <view class="modal-label">记症状</view>
      </view>
    </view>
    <view class="modal-close" bindtap="hideAddModal">
      <text class="close-icon">×</text>
    </view>
  </view>
</view>
