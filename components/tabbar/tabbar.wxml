<view class="tabbar-placeholder"></view>
<view class="tabbar {{isDark ? 'dark' : ''}}">
  <view class="tabbar-inner">
    <view class="tab-item {{activeTab === 'home' ? 'active' : ''}}" bindtap="onTabChange" data-tab="home" data-url="/pages/home/home">
      <view class="icon-container">
        <image class="icon-image" src="{{activeTab === 'home' ? '/images/home_active.png' : '/images/home.png'}}" mode="aspectFill"></image>
      </view>
      <text class="label">首页</text>
    </view>

    <view class="tab-item add-tab" bindtap="showAddModal">
      <view class="add-button-wrap">
        <view class="add-button">
          <image class="icon-image" src="/images/addRecord_big.png" mode="aspectFill"></image>
        </view>
      </view>
      <text class="label mt-record">添加</text>
    </view>

    <view class="tab-item {{activeTab === 'records' ? 'active' : ''}}" bindtap="onTabChange" data-tab="records" data-url="/pages/records/records">
      <view class="icon-container">
        <image class="icon-image" src="{{activeTab === 'records' ? '/images/record_active.png' : '/images/record.png'}}" mode="aspectFill"></image>
      </view>
      <text class="label">回顾</text>
    </view>
  </view>
</view>

<view class="modal-overlay {{isDark ? 'dark' : ''}}" wx:if="{{showAddModal}}" catchtap="hideAddModal">
  <view class="modal-container" catchtap="noop">
    <view class="modal-handle"></view>
    <view class="modal-header">
      <view>
        <view class="modal-title">添加什么？</view>
        <view class="modal-subtitle">选择要添加的内容</view>
      </view>
      <view class="modal-close" bindtap="hideAddModal"><text class="close-icon">×</text></view>
    </view>
    <view class="item-entry" bindtap="navigateToReminder">
      <view class="modal-icon blue item-icon">
        <image class="action-icon" src="/images/action-schedule.svg" mode="aspectFit"></image>
      </view>
      <view class="entry-copy">
        <text class="entry-title">添加事项</text>
        <text class="entry-desc">之后需要做：用药、复查、治疗或问诊</text>
      </view>
      <text class="entry-arrow">›</text>
    </view>
    <view class="record-heading">
      <text class="record-title">添加记录</text>
      <text class="record-desc">已经发生，留下一条健康信息</text>
    </view>
    <view class="modal-grid record-grid">
      <view class="modal-button" bindtap="navigateToSymptoms">
        <view class="modal-icon orange">
          <image class="action-icon" src="/images/action-status.svg" mode="aspectFit"></image>
        </view>
        <view class="modal-label">身体状态</view>
        <view class="modal-card-desc">症状和感受</view>
      </view>
      <view class="modal-button" bindtap="navigateToWeight">
        <view class="modal-icon green">
          <image class="action-icon" src="/images/action-weight.svg" mode="aspectFit"></image>
        </view>
        <view class="modal-label">体重</view>
        <view class="modal-card-desc">记录一次数据</view>
      </view>
    </view>
  </view>
</view>
